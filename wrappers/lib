#!/usr/bin/env bash

script_dir=$(dirname "$0")
. "$script_dir/msvcenv.sh"

runner="$script_dir/wine-msvc.sh"
lib="$BINDIR/lib.exe"

len=0

# Approximate command-line length (including spaces between arguments).
for arg; do
    ((len += ${#arg} + 1))
done

if ((len > 30000)); then
    rsp=$(mktemp "${TMPDIR:-/tmp}/lib.XXXXXX.rsp") || exit 1
    trap 'rm -f "$rsp"' EXIT

    {
        for arg; do
            printf '%s\n' "$arg"
        done
    } >"$rsp"

    exec "$runner" "$lib" "@$rsp"
fi

exec "$runner" "$lib" "$@"
